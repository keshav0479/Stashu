# Stashu Client Environment Variables

# API URL (defaults to localhost:3000 for development)
VITE_API_URL=http://localhost:3000/api

# Blossom server URL — must accept opaque application/octet-stream uploads
# (blossom.primal.net does NOT: it 415-rejects encrypted blobs)
VITE_BLOSSOM_URL=https://blossom.ditto.pub
